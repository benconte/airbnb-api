// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  HOST
  GUEST
}

enum ListingType {
  APARTMENT
  HOUSE
  VILLA
  CABIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

enum DisputeReason {
  PROPERTY_CONDITION
  PAYMENT_ISSUE
  HOST_BEHAVIOUR
  GUEST_BEHAVIOUR
  CANCELLATION_POLICY
  OTHER
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  username         String    @unique
  phone            String
  password         String
  role             Role      @default(GUEST)
  avatar           String? // Cloudinary URL
  avatarPublicId   String? // needed to delete the old file before uploading a new one
  bio              String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  resetToken       String?
  resetTokenExpiry DateTime?

  listings   Listing[]
  bookings   Booking[]
  reviews    Review[]
  wishlists  Listing[]  @relation("UserWishlists")
  disputes   Dispute[]  @relation("DisputeReporter")

  @@index([name])
  @@index([role])
}

model Listing {
  id            String      @id @default(uuid())
  title         String
  description   String
  location      String
  pricePerNight Float
  guests        Int
  type          ListingType
  amenities     String[]
  rating        Float?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  host     User           @relation(fields: [hostId], references: [id], onDelete: Cascade)
  hostId   String
  bookings Booking[]
  photos   ListingPhoto[]
  reviews  Review[]
  wishlistedBy User[] @relation("UserWishlists")

  // Indexes for frequently filtered fields
  @@index([location])
  @@index([pricePerNight])
  @@index([hostId])
  @@index([type])
}

model ListingPhoto {
  id       String @id @default(uuid())
  url      String // Cloudinary URL — for displaying
  publicId String // Cloudinary public_id — for deleting

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
}

model Booking {
  id         String        @id @default(uuid())
  checkIn    DateTime
  checkOut   DateTime
  totalPrice Float
  status     BookingStatus @default(PENDING)
  createdAt  DateTime      @default(now())

  guest     User      @relation(fields: [guestId], references: [id], onDelete: Cascade)
  guestId   String
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String
  guests    Int       @default(1)
  disputes  Dispute[]

  @@index([guestId])
  @@index([listingId])
  @@index([status])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listingId String

  @@index([userId])
  @@index([listingId])
}

model Dispute {
  id          String        @id @default(uuid())
  title       String
  description String
  reason      DisputeReason @default(OTHER)
  status      DisputeStatus @default(OPEN)
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reporter    User    @relation("DisputeReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId  String
  booking     Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId   String

  @@index([reporterId])
  @@index([bookingId])
  @@index([status])
}
